{
  "command_timeout": 5,
  "templates_folder": "Libraries/Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": true,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Notes",
      "template": "Libraries/Templates/NoteTemplate.md"
    },
    {
      "folder": "Inbox",
      "template": "Libraries/Templates/InboxTemplate.md"
    },
    {
      "folder": "Projects",
      "template": "Libraries/Templates/ProjectTemplate.md"
    },
    {
      "folder": "References",
      "template": "Libraries/Templates/ReferenceTemplate.md"
    },
{
      "folder": "Generated/Sessions",
      "template": "Libraries/Templates/SessionTemplate.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": true,
  "enabled_templates_hotkeys": [
    ""
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1
}
